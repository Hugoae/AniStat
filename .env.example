# Supabase (browser — public anon key, used for reads AND writes)
# Writes rely on RLS policies that allow anon INSERT/UPDATE on the cache tables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

ANILIST_SERVER_CACHE_TTL_SECONDS=600
ANILIST_SERVER_CACHE_TTL_USER_SECONDS=900
ANILIST_SERVER_CACHE_TTL_LIST_SECONDS=600
ANILIST_SERVER_CACHE_TTL_ACTIVITY_SECONDS=120
ANILIST_SERVER_CACHE_TTL_VOLATILE_SECONDS=60
ANILIST_PROXY_LOGS=0

# Optional shared server cache (recommended for Vercel)
# https://upstash.com/ (Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# URL publique du site (SEO : og:image, JSON-LD, logo Google). Ex. https://aniliststat.vercel.app
VITE_SITE_URL=
