# =============================================================================
#  AniStat — variables d'environnement (exemple)
# =============================================================================
#  Copier ce fichier en `.env.local` puis renseigner les valeurs.
#  NE JAMAIS committer `.env.local` ni de vraies clés (déjà bloqué par .gitignore).
#
#  Règle de préfixe Vite :
#   - VITE_*  → INJECTÉ DANS LE BUNDLE NAVIGATEUR (= public, visible par tous).
#               N'y mettre QUE des valeurs non sensibles (URL, clé anon).
#   - sans VITE_ → côté serveur uniquement (fonctions /api), jamais exposé.
# =============================================================================

# ── Supabase (navigateur) — clé PUBLIQUE anon ───────────────────────────────
# La clé anon est conçue pour être publique : elle est protégée par les
# politiques Row Level Security (RLS) et ne touche que des données AniList
# publiques mises en cache (lectures + écritures de cache).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Cache serveur du proxy AniList (optionnel) ──────────────────────────────
ANILIST_SERVER_CACHE_TTL_SECONDS=600
ANILIST_SERVER_CACHE_TTL_USER_SECONDS=900
ANILIST_SERVER_CACHE_TTL_LIST_SECONDS=600
ANILIST_SERVER_CACHE_TTL_ACTIVITY_SECONDS=120
ANILIST_SERVER_CACHE_TTL_VOLATILE_SECONDS=60
ANILIST_PROXY_LOGS=0

# ── Cache partagé Upstash Redis (optionnel, recommandé sur Vercel) ──────────
# SECRET serveur : ne JAMAIS préfixer par VITE_ (sinon exposé dans le bundle).
# https://upstash.com/ (Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── URL publique du site (SEO : og:image, JSON-LD, logo Google) ─────────────
# Ex. https://aniliststat.vercel.app — sur Vercel, déduit de VERCEL_URL si vide.
VITE_SITE_URL=
